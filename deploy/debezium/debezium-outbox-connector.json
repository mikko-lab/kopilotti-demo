{
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "tasks.max": "1",
    "plugin.name": "pgoutput",
    "database.hostname": "${env:DEBEZIUM_DATABASE_HOST}",
    "database.port": "${env:DEBEZIUM_DATABASE_PORT}",
    "database.user": "${env:DEBEZIUM_DATABASE_USER}",
    "database.password": "${env:DEBEZIUM_DATABASE_PASSWORD}",
    "database.dbname": "${env:DEBEZIUM_DATABASE_NAME}",
    "topic.prefix": "kopilotti-postgres-cdc",
    "slot.name": "kopilotti_outbox",
    "publication.name": "kopilotti_outbox_publication",
    "publication.autocreate.mode": "disabled",
    "table.include.list": "public.transactional_outbox",
    "snapshot.mode": "initial",
    "skipped.operations": "u,d,t",
    "tombstones.on.delete": "false",
    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.table.field.event.id": "event_id",
    "transforms.outbox.table.field.event.key": "transaction_id",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.table.expand.json.payload": "true",
    "transforms.outbox.table.json.payload.null.behavior": "optional_bytes",
    "transforms.outbox.table.fields.additional.placement": "event_type:header:eventType",
    "transforms.outbox.route.by.field": "event_type",
    "transforms.outbox.route.topic.replacement": "kopilotti.transactions.events",
    "transforms.outbox.table.op.invalid.behavior": "fatal",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
}
