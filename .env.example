ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGIN=https://mikko-lab.github.io
PORT=3001
NEGOTIATION_POLICY_PATH=/run/secrets/kopilotti-negotiation-policy.json
NEGOTIATION_DATA_DIR=/var/lib/kopilotti/negotiations
ENABLE_CUSTOMER_NEGOTIATION_DEMO=false
CONDITION_REPORT_PATH=/run/secrets/kopilotti-condition-reports.json
HANDOVER_POLICY_PATH=/run/secrets/kopilotti-handover-policy.json
ENABLE_SIMULATED_PURCHASE_PROVIDERS=false
PURCHASE_INTEGRATION_SECRET=replace-with-secret
POSTGRES_DB=kopilotti_db
POSTGRES_USER=kopilotti_user
POSTGRES_PASSWORD=replace-with-a-local-app-password
DEBEZIUM_DATABASE_USER=debezium_user
DEBEZIUM_DATABASE_PASSWORD=replace-with-a-separate-local-cdc-password
POSTGRES_PORT=5432
KAFKA_PORT=29092
DEBEZIUM_CONNECT_PORT=8083
