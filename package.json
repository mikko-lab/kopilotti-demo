{
  "name": "kopilotti-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.18.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:metrics": "node src/transaction-core/metrics-server.ts",
    "dev": "node --watch server.js",
    "dev:static": "npx --yes serve . -l 8090",
    "generate:inventory": "node scripts/generate-inventory.js",
    "typecheck": "tsc --project tsconfig.json",
    "test": "npm run typecheck && node --test tests/**/*.test.js tests/**/*.test.ts",
    "test:e2e:cdc": "RUN_CDC_E2E=1 node --test tests/transaction-core/e2e-cdc-transaction.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  }
}
